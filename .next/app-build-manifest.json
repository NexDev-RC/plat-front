      "static/chunks/app/(main)/page.js"
    ],
    "/login/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/login/page.js"
    ],
    "/(main)/dashboard/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(main)/dashboard/page.js"
    ],
    "/(main)/admin/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(main)/admin/page.js"
    ],
    "/(main)/admin/courses/[id]/edit/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(main)/admin/courses/[id]/edit/page.js"
    ],
    "/(main)/courses/[courseId]/page": [
